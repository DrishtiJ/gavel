{
  "name": "gavel",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "dev": "convex dev --start 'vp dev'",
    "build": "vp build && tsc --noEmit",
    "deploy": "vp build && pnpm run deploy:blaxel && pnpm run deploy:convex",
    "deploy:blaxel": "blaxel/codex-browsercode/push.sh",
    "deploy:convex": "npx convex deploy --yes",
    "start": "node .output/server/index.mjs",
    "format": "vp fmt .",
    "lint": "tsc && eslint .  --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "prepare": "vp config"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@blaxel/core": "0.2.84",
    "@convex-dev/react-query": "0.1.0",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@phosphor-icons/react": "^2.1.10",
    "@tanstack/react-query": "^5.99.0",
    "@tanstack/react-router": "^1.168.22",
    "@tanstack/react-router-devtools": "^1.166.13",
    "@tanstack/react-router-with-query": "^1.130.17",
    "@tanstack/react-start": "^1.167.41",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "convex": "^1.36.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "redaxios": "^0.5.1",
    "shadcn": "^4.7.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@convex-dev/eslint-plugin": "^1.2.2",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/eslint-config": "^0.4.0",
    "@types/bun": "^1.3.14",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "autoprefixer": "^10.5.0",
    "nitro": "3.0.260429-beta",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.3",
    "vite": "catalog:",
    "vite-plus": "catalog:"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "@tailwindcss/oxide"
    ]
  },
  "packageManager": "pnpm@11.1.2"
}
